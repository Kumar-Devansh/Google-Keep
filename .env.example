# Backend Environment Variables
NODE_ENV=production
PORT=5000
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/googlekeep
JWT_SECRET=your-secure-jwt-secret-key-here-change-this-in-production
CORS_ORIGIN=https://yourdomain.com

# MongoDB Local (used when profile: dev is enabled)
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=admin
MONGO_DB_NAME=googlekeep

# Frontend Environment Variables
REACT_APP_API_URL=https://api.yourdomain.com
